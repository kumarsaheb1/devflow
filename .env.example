# GitHub personal access token — needs: repo, read:org, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Org or username to analyse
GITHUB_OWNER=your-org

# Optional: comma-separated repos to scope to (blank = all repos)
GITHUB_REPOS=

# How many days of history to analyse (default: 90)
DEVFLOW_LOOKBACK_DAYS=90

RUST_LOG=warn
